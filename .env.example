# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API

# Project URL (same for all dashboard versions)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable / anon key  (client-safe — shown as "Publishable key" in new dashboard,
# "anon public" in older dashboard). Optional for this app — all calls are server-side.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Secret key  (server-side only — NEVER expose to the browser)
# New dashboard:  Settings → API → "Secret key"  → set as SUPABASE_SECRET_KEY
# Old dashboard:  Settings → API → service_role  → set as SUPABASE_SERVICE_ROLE_KEY
# The app checks both names; use whichever your dashboard shows.
SUPABASE_SECRET_KEY=your-secret-key

# ─── Admin auth ───────────────────────────────────────────────────────────────
JWT_SECRET=a-long-random-secret-at-least-32-chars
ADMIN_PASSWORD=your-admin-password

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_TO_EMAIL=nabilahmed.cloud@gmail.com
RESEND_FROM_EMAIL=onboarding@resend.dev


